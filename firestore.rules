rules_version = '2';

// ============================================================================
// ATURAN KEAMANAN FIRESTORE
// ============================================================================
// Cara pasang:
// Firebase Console → Firestore Database → tab "Rules" → tempel isi file ini →
// klik "Publish"
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Profil user: siapa saja yang login boleh baca (perlu ini untuk fitur
    // cari user via email), tapi hanya pemilik akun yang boleh menulis
    // dokumennya sendiri.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Chat (1-on-1 maupun grup): hanya anggota chat yang boleh membaca,
    // membuat, atau memperbarui (mis. lastMessage) dokumen chat tersebut.
    match /chats/{chatId} {
      allow read, update: if request.auth != null && request.auth.uid in resource.data.members;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.members;

      // Pesan di dalam sebuah chat: hanya anggota chat itu yang boleh
      // membaca atau mengirim pesan baru. Pesan tidak boleh diubah/dihapus.
      match /messages/{messageId} {
        allow read, create: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
      }
    }
  }
}
